<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add a Wish</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="container">
        <h1>✨ Add a New Wish</h1>

        <form method="post" action="/add" class="wish-form">
            <input type="text" name="title" placeholder="Something you want to do..." required>

            <div class="form-actions">
                <button type="submit" class="btn btn-done">Add Wish</button>
                <a href="/" class="btn btn-cancel">Cancel</a>
            </div>
        </form>
    </div>
    
</body>
</html>